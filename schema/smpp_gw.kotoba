// Smpp_gw clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace smpp_gw {

    entity Subscriber {
        id: string @unique
        imsi: string
        msisdn: string
        plan: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Session {
        id: string @unique
        subscriberId: string
        apn: string
        startedAt: datetime
        bytesUsed: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Message {
        id: string @unique
        fromAddr: string
        toAddr: string
        body: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Number {
        id: string @unique
        e164: string
        type: string
        assignedTo: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Terminal {
        id: string @unique
        serial: string
        satellite: string
        signalDb: float
        online: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity UsageRecord {
        id: string @unique
        subscriberId: string
        quantity: float
        unit: string
        ratedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
